# ============================================================
# 同人/原创写作资料辅助Agent — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的 API keys

# --- LLM Provider ---
# 可选: claude-sonnet-5, claude-opus-4-8, gpt-4o, gpt-4o-mini
LITELLM_MODEL=claude-sonnet-5

# --- API Keys (至少配置一个) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# --- Embedding ---
# 可选: text-embedding-3-small, text-embedding-3-large
EMBEDDING_MODEL=text-embedding-3-small

# --- Storage ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Logging ---
LOG_LEVEL=INFO
